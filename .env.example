# Ghost Font CAPTCHA - environment configuration
# Copy to .env and adjust for your deployment.

# Public URL where the service is reachable (used to build widget/script URLs).
PUBLIC_BASE_URL=http://localhost:5000

# Secret used for Flask session signing. Set to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Redis connection string. If set, the token store and rate-limiter use Redis
# (horizontally scalable). If unset, an in-memory fallback is used (single
# instance only). Example: redis://localhost:6379/0
REDIS_URL=

# Comma-separated list of origins allowed to embed the widget.
# Leave empty to allow any origin (default, easiest for drop-in use).
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
ALLOWED_ORIGINS=

# Challenge (widget -> server) lifetime in seconds.
CHALLENGE_TTL=180

# Token (form -> siteverify) lifetime in seconds.
TOKEN_TTL=120

# Pre-generation pool sizing.
POOL_MIN=8
POOL_MAX=32
POOL_REFILL_INTERVAL=2.0

# Rate limits.
RATE_CHALLENGE=30 per minute
RATE_VERIFY=30 per minute
RATE_SITEVERIFY=120 per minute
